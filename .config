# 1. 核心硬件架構 (NN6000 v2 高通 IPQ60xx)
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_link_nn6000-v2=y

# 2. 內核與 eBPF 滿血解鎖 (daed 必備，解決內存報錯)
CONFIG_DEBUG_INFO_BTF=y
CONFIG_KERNEL_CGROUPS=y
CONFIG_KERNEL_MEMCG=y
CONFIG_PACKAGE_kmod-veth=y

# 3. 分區擴容 (針對 8GB eMMC，分配 6GB 畀系統裝嘢)
CONFIG_TARGET_KERNEL_PARTSIZE=64
CONFIG_TARGET_ROOTFS_PARTSIZE=6144

# 4. 預裝網頁版「RUN 安裝器」與必備底層依賴
CONFIG_PACKAGE_luci-app-run=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_jq=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_ca-certificates=y

# 5. 預裝 PassWall 2 連同 Xray/Hy2/TUIC5 核心
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Xray=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Hysteria2=y
CONFIG_PACKAGE_luci-app-passwall_INCLUDE_Tuic_V5=y

# 6. 預裝 Docker 容器引擎
CONFIG_PACKAGE_luci-app-dockerman=y

# 7. AdGuard Home 廣告過濾與 DNS 清潔
CONFIG_PACKAGE_luci-app-adguardhome=y

# 8. 雲端同步神器 (打通 115 / E5 網盤)
CONFIG_PACKAGE_rclone=y

# 9. Argon 靚爆主題與專屬配置面板
CONFIG_PACKAGE_luci-theme-argon=y
CONFIG_PACKAGE_luci-app-argon-config=y

# 10. 實時性能圖表監控 (CPU溫度、流量曲線)
CONFIG_PACKAGE_luci-app-statistics=y

# 11. 必备磁盘与分区工具 (彻底告别 opkg 依赖地狱) 
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-usb-storage=y

# --- 11. 必备磁盘与分区工具 (保留你寻晚完美劏碟嘅战果) ---
CONFIG_PACKAGE_fdisk=y
CONFIG_PACKAGE_cfdisk=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_resize2fs=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-usb-storage=y

# --- 12. daed 终极内核 eBPF/BTF 支持 (完美解决 no BTF found 报错) ---
CONFIG_DEVEL=y
CONFIG_BPF_TOOLCHAIN_HOST=y
# CONFIG_BPF_TOOLCHAIN_NONE is not set
CONFIG_KERNEL_BPF_EVENTS=y
CONFIG_KERNEL_CGROUP_BPF=y
CONFIG_KERNEL_DEBUG_INFO=y
CONFIG_KERNEL_DEBUG_INFO_BTF=y
# CONFIG_KERNEL_DEBUG_INFO_REDUCED is not set
CONFIG_KERNEL_XDP_SOCKETS=y

# 补充 daed 虚拟网卡底层依赖 (0.5.1版本以上强烈建议)
CONFIG_PACKAGE_kmod-veth=y

